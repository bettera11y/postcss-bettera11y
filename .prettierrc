{
    "tabWidth": 4,
    "semi": true,
    "singleQuote": false,
    "endOfLine": "lf",
    "trailingComma": "none",
    "printWidth": 120,
    "useTabs": false,
    "quoteProps": "consistent",
    "jsxSingleQuote": false,
    "bracketSpacing": true,
    "objectWrap": "preserve",
    "bracketSameLine": true,
    "arrowParens": "always"
}
