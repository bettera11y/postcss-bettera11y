{
    "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
    "release-type": "node",
    "include-component-in-tag": false,
    "include-v-in-tag": true,
    "packages": {
        ".": {
            "release-type": "node",
            "changelog-path": "CHANGELOG.md",
            "changelog-sections": [
                {
                    "type": "feat",
                    "section": "Features"
                },
                {
                    "type": "fix",
                    "section": "Bug Fixes"
                },
                {
                    "type": "perf",
                    "section": "Performance"
                },
                {
                    "type": "refactor",
                    "section": "Refactors"
                },
                {
                    "type": "docs",
                    "section": "Documentation"
                },
                {
                    "type": "test",
                    "section": "Tests"
                },
                {
                    "type": "chore",
                    "section": "Miscellaneous"
                },
                {
                    "type": "ci",
                    "section": "CI"
                },
                {
                    "type": "build",
                    "section": "Build System"
                }
            ]
        }
    }
}
